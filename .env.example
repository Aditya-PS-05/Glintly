# --- Database ---
# Postgres connection string (Neon, Supabase, RDS, etc.)
# To enable Prisma Accelerate, set DATABASE_URL to the prisma:// URL from
# https://console.prisma.io/ — withAccelerate() picks it up automatically.
DATABASE_URL="postgresql://user:password@host:5432/glintly?schema=public"

# --- Auth (NextAuth) ---
# 32+ random bytes. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Full origin of the deployed app (required in production)
NEXTAUTH_URL="http://localhost:3000"

# --- OAuth providers ---
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- AI / sandboxes ---
# OpenAI key used by the Inngest code-generation agent
OPENAI_API_KEY=""
# E2B API key for spawning code sandboxes
E2B_API_KEY=""

# --- Inngest ---
# Local dev CLI auto-discovers; set these in production
# INNGEST_EVENT_KEY=""
# INNGEST_SIGNING_KEY=""

# --- Rate limiting (optional) ---
# If set, rate limiter uses Upstash Redis; otherwise falls back to in-memory
# (safe for single-instance dev, but per-instance in serverless production).
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# --- Error tracking (optional) ---
# If set, the app reports server + edge errors to Sentry.
# SENTRY_DSN=""
# SENTRY_TRACES_SAMPLE_RATE="0.1"
# Client-side (browser) errors require the NEXT_PUBLIC_ variant.
# NEXT_PUBLIC_SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"

# --- Razorpay (billing) ---
# Create an account at https://dashboard.razorpay.com/ and switch to Live when ready.
# Subscriptions → Plans → create recurring plans and copy the IDs (plan_XXX) below.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Set this to the "secret" value from Settings → Webhooks; the endpoint is
# POST /api/razorpay/webhook and must receive all `subscription.*` events.
RAZORPAY_WEBHOOK_SECRET=""
# plan_XXX ids from the Razorpay dashboard
RAZORPAY_PRO_PLAN_ID=""
RAZORPAY_TEAM_PLAN_ID=""
# Browser-visible key id used by the Razorpay Checkout.js script
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# --- Public runtime ---
# Browser-visible origin used by the tRPC client to build absolute URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
